# apps/web/.env.example — used by Next.js (pnpm dev, pnpm build)

# Database (local dev — matches docker-compose)
DATABASE_URL="postgresql://lumigraph:lumigraph@localhost:5432/lumigraph_db"

# Database (Vercel deployed — IAM auth, no DATABASE_URL needed)
# These are set in the Vercel dashboard per environment.
# DB_HOST=""          # Terraform output: db_instance_endpoint
# DB_PORT="5432"
# DB_NAME="lumigraph_db"
# DB_USER="app_user"
# AWS_ROLE_ARN=""     # Terraform output: vercel_db_connect_role_arn

# Auth — core (Auth.js v5)
# Generate with: openssl rand -base64 33
AUTH_SECRET=""

# Auth — GitHub OAuth (AUTH_* auto-detected by Auth.js v5)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Auth — Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Auth — Email magic link (SMTP)
# Format: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=""
EMAIL_FROM="Lumigraph <noreply@lumigraph.com>"

# AWS / S3 (local dev)
AWS_REGION="us-east-1"
AWS_S3_BUCKET="lumigraph-artifacts-<env>-<account-id>-<region>"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Unified upload max size (optional; default 1GB)
# UPLOAD_MAX_SIZE_BYTES="1073741824"

# Home Astro Hub — daily canvas + chatbot
OPENAI_API_KEY=""           # Required for daily canvas synthesis and chatbot
NASA_API_KEY=""             # Optional; improves NASA API rate limit (get at https://api.nasa.gov/)
