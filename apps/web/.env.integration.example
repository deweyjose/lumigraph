# apps/web/.env.integration.example
# Copy to .env.integration to run S3 integration tests locally against LocalStack.
# Optional: if unset, S3 integration tests are skipped (other integration tests still run).
#
# 1. Start LocalStack:  docker compose up -d localstack
# 2. Copy this file:     cp .env.integration.example .env.integration
# 3. Run integration:    pnpm test:integration  (from repo root)
#
# LocalStack does not support SDK default request checksums; this disables them.
AWS_REQUEST_CHECKSUM_CALCULATION=WHEN_REQUIRED

AWS_S3_ENDPOINT=http://localhost:4566
AWS_S3_BUCKET=test-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
