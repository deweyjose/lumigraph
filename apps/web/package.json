{
  "name": "@lumigraph/web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=../../prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint . --config ../../eslint.config.mjs --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run --workspace ../../vitest.workspace.mts --project web",
    "test:integration": "vitest run --workspace ../../vitest.workspace.mts --project web-integration --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@lumigraph/db": "workspace:*",
    "@prisma/client": "5.22.0",
    "@tailwindcss/postcss": "^4.2.1",
    "argon2": "^0.44.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "7.0.13",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "prettier": "3.2.5",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
