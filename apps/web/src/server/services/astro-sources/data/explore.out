{
  "mainFeedXml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><rss version=\"2.0\"\n\txmlns:content=\"http://purl.org/rss/1.0/modules/content/\"\n\txmlns:wfw=\"http://wellformedweb.org/CommentAPI/\"\n\txmlns:dc=\"http://purl.org/dc/elements/1.1/\"\n\txmlns:atom=\"http://www.w3.org/2005/Atom\"\n\txmlns:sy=\"http://purl.org/rss/1.0/modules/syndication/\"\n\txmlns:slash=\"http://purl.org/rss/1.0/modules/slash/\"\n\txmlns:media=\"http://search.yahoo.com/mrss/\" >\n\n<channel>\n\t<title>NASA</title>\n\t<atom:link href=\"https://www.nasa.gov/feed/\" rel=\"self\" type=\"application/rss+xml\" />\n\t<link>https://www.nasa.gov</link>\n\t<description>Official National Aeronautics and Space Administration Website</description>\n\t<lastBuildDate>Wed, 11 Mar 2026 20:36:11 +0000</lastBuildDate>\n\t<language>en-US</language>\n\t<sy:updatePeriod>\n\thourly\t</sy:updatePeriod>\n\t<sy:updateFrequency>\n\t1\t</sy:updateFrequency>\n\t<generator>https://wordpress.org/?v=6.8.5</generator>\n\t<item>\n\t\t<title>2026 William T. Pecora Award Nominations Now Being Accepted</title>\n\t\t<link>https://science.nasa.gov/missions/landsat/2026-william-t-pecora-award-nominations-now-being-accepted/</link>\n\t\t\n\t\t<dc:creator><![CDATA[]]></dc:creator>\n\t\t<pubDate>Wed, 11 Mar 2026 20:18:22 +0000</pubDate>\n\t\t\t\t<category><![CDATA[Earth]]></category>\n\t\t<category><![CDATA[Landsat]]></category>\n\t\t<guid isPermaLink=\"false\">https://science.nasa.gov/missions/landsat/2026-william-t-pecora-award-nominations-now-being-accepted/</guid>\n\n\t\t\t\t\t<description><![CDATA[The William T. Pecora Award is presented annually to individuals or teams using satellite or aerial remote sensing that make outstanding contributions toward understanding the Earth (land, oceans, and air), educating the next generation of scientists, informing decision-makers, or supporting natural or human-induced disaster response. Both national and international nominations are welcome.]]></description>\n\t\t\t\t\t\t\t\t\t\t<co