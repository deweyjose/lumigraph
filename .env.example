# Database (local dev — password-based connection)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lumigraph_db"

# Database (Vercel deployed — IAM auth, no DATABASE_URL needed)
# These are set in the Vercel dashboard per environment.
# DB_HOST=""          # Terraform output: db_instance_endpoint
# DB_PORT="5432"
# DB_NAME="lumigraph_db"
# DB_USER="app_user"
# AWS_ROLE_ARN=""     # Terraform output: vercel_db_connect_role_arn

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GITHUB_ID=""
GITHUB_SECRET=""

# AWS / S3 (local dev)
AWS_REGION="us-east-1"
AWS_S3_BUCKET="lumigraph-artifacts-<env>-<account-id>-<region>"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
