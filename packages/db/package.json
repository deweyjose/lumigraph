{
  "name": "@lumigraph/db",
  "private": true,
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "eslint . --config ../../eslint.config.mjs",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run --workspace ../../vitest.workspace.mts --project db",
    "test:integration": "vitest run --workspace ../../vitest.workspace.mts --project db-integration --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1000.0",
    "@prisma/client": "5.22.0",
    "@vercel/oidc-aws-credentials-provider": "^3.0.7"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
