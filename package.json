{
  "name": "lumigraph",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "lint": "pnpm run -r lint",
    "format": "pnpm run -r format",
    "format:fix": "pnpm run -r format:fix",
    "test": "pnpm run -r test",
    "test:integration": "pnpm run -r test:integration",
    "test:integration:docker": "docker compose run --rm integration",
    "typecheck": "pnpm run -r typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "dev:db": "docker compose up -d && sleep 5 && pnpm db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "9.15.0",
    "@prisma/client": "5.22.0",
    "dotenv": "17.3.1",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "prettier": "3.2.5",
    "prisma": "5.22.0",
    "typescript-eslint": "8.18.0"
  }
}
