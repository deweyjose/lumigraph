generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DatasetVisibility {
  PRIVATE
  UNLISTED
  PUBLIC

  @@map("dataset_visibility")
}

enum PostVisibility {
  DRAFT
  PRIVATE
  UNLISTED
  PUBLIC

  @@map("post_visibility")
}

enum TargetType {
  GALAXY
  NEBULA
  STAR_CLUSTER
  PLANETARY_NEBULA
  OTHER

  @@map("target_type")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts   Account[]
  imagePosts ImagePost[]
  datasets   Dataset[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model VerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ImagePost {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @db.Uuid @map("user_id")
  slug               String         @unique
  title              String
  description        String?
  visibility         PostVisibility @default(DRAFT)
  targetName         String?        @map("target_name")
  targetType         TargetType?    @map("target_type")
  captureDate        DateTime?      @map("capture_date")
  bortle             Int?
  finalImageUrl      String?        @map("final_image_url")
  finalImageThumbUrl String?        @map("final_image_thumb_url")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  datasets Dataset[]

  @@index([userId])
  @@map("image_posts")
}

model Dataset {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid @map("user_id")
  imagePostId String?           @db.Uuid @map("image_post_id")
  title       String
  description String?
  visibility  DatasetVisibility @default(PRIVATE)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  imagePost  ImagePost? @relation(fields: [imagePostId], references: [id])
  artifacts  DatasetArtifact[]

  @@index([userId])
  @@index([imagePostId])
  @@map("datasets")
}

model DatasetArtifact {
  id        String   @id @default(uuid()) @db.Uuid
  datasetId String   @db.Uuid @map("dataset_id")
  filename  String
  fileType  String   @map("file_type")
  s3Key     String   @map("s3_key")
  sizeBytes BigInt   @map("size_bytes")
  checksum  String?
  createdAt DateTime @default(now()) @map("created_at")

  dataset Dataset @relation(fields: [datasetId], references: [id])

  @@index([datasetId])
  @@map("dataset_artifacts")
}
