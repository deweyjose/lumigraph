generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PUBLISHED

  @@map("post_status")
}

enum TargetType {
  GALAXY
  NEBULA
  STAR_CLUSTER
  PLANETARY_NEBULA
  OTHER

  @@map("target_type")
}

enum IntegrationSetVisibility {
  PRIVATE

  @@map("integration_set_visibility")
}

enum AssetKind {
  INTEGRATION
  FINAL_IMAGE
  FINAL_THUMB

  @@map("asset_kind")
}

enum AssetStatus {
  PRESIGNED
  UPLOADED

  @@map("asset_status")
}

enum DownloadJobStatus {
  PENDING
  RUNNING
  READY
  FAILED
  CANCELLED

  @@map("download_job_status")
}

enum WorkflowSubjectType {
  POST
  INTEGRATION_SET

  @@map("workflow_subject_type")
}

enum WorkflowSessionStatus {
  ACTIVE
  ARCHIVED

  @@map("workflow_session_status")
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED

  @@map("workflow_run_status")
}

enum WorkflowRunTrigger {
  MANUAL
  RESUME
  RETRY
  SYSTEM

  @@map("workflow_run_trigger")
}

enum RunToolCallStatus {
  SUCCEEDED
  FAILED

  @@map("run_tool_call_status")
}

enum RunArtifactRefType {
  POST
  INTEGRATION_SET
  ASSET
  DOWNLOAD_JOB

  @@map("run_artifact_ref_type")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  posts           Post[]
  integrationSets IntegrationSet[]
  assets          Asset[]
  downloadJobs    DownloadJob[]
  workflowSessions WorkflowSession[]
  workflowRuns     WorkflowRun[]
  runToolCalls     RunToolCall[]
  runArtifactRefs  RunArtifactRef[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model VerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Post {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @db.Uuid @map("user_id")
  slug               String         @unique
  title              String
  description        String?
  status             PostStatus     @default(DRAFT)
  targetName         String?        @map("target_name")
  targetType         TargetType?    @map("target_type")
  captureDate        DateTime?      @map("capture_date")
  bortle             Int?
  finalImageAssetId  String?        @db.Uuid @map("final_image_asset_id")
  finalThumbAssetId  String?        @db.Uuid @map("final_thumb_asset_id")
  publishedAt        DateTime?      @map("published_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id])
  integrationSets  IntegrationSet[]
  assets           Asset[]          @relation("PostAssets")
  finalImageAsset  Asset?           @relation("PostFinalImage", fields: [finalImageAssetId], references: [id], onDelete: SetNull)
  finalThumbAsset  Asset?           @relation("PostFinalThumb", fields: [finalThumbAssetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt])
  @@map("posts")
}

model IntegrationSet {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid @map("user_id")
  postId      String?           @db.Uuid @map("post_id")
  title       String
  notes       String?
  visibility  IntegrationSetVisibility @default(PRIVATE)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id])
  post      Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  assets    Asset[]
  downloadJobs DownloadJob[]

  @@index([userId])
  @@index([postId])
  @@map("integration_sets")
}

model Asset {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @db.Uuid @map("user_id")
  integrationSetId String?     @db.Uuid @map("integration_set_id")
  postId           String?     @db.Uuid @map("post_id")
  kind             AssetKind
  relativePath     String      @map("relative_path")
  filename  String
  contentType String
  sizeBytes        BigInt      @map("size_bytes")
  s3Key            String      @map("s3_key")
  status           AssetStatus @default(PRESIGNED)
  checksum         String?
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user             User            @relation(fields: [userId], references: [id])
  integrationSet   IntegrationSet? @relation(fields: [integrationSetId], references: [id], onDelete: Cascade)
  post             Post?           @relation("PostAssets", fields: [postId], references: [id], onDelete: Cascade)
  finalImageForPost Post[]         @relation("PostFinalImage")
  finalThumbForPost Post[]         @relation("PostFinalThumb")

  @@index([userId])
  @@index([integrationSetId, relativePath])
  @@index([postId, kind])
  @@index([s3Key])
  @@map("assets")
}

model DownloadJob {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @db.Uuid @map("user_id")
  integrationSetId  String            @db.Uuid @map("integration_set_id")
  selectedPathsJson Json              @map("selected_paths_json")
  status            DownloadJobStatus @default(PENDING)
  totalFiles        Int?              @map("total_files")
  completedFiles    Int               @default(0) @map("completed_files")
  lastProgressAt    DateTime?         @map("last_progress_at")
  outputS3Key       String?           @map("output_s3_key")
  outputSizeBytes   BigInt?           @map("output_size_bytes")
  errorMessage      String?           @map("error_message")
  completedAt       DateTime?         @map("completed_at")
  expiresAt         DateTime?         @map("expires_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrationSet IntegrationSet @relation(fields: [integrationSetId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([integrationSetId, createdAt])
  @@index([status, createdAt])
  @@map("download_jobs")
}

model DailyCanvas {
  date      DateTime @id @db.Date
  content   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("daily_canvas")
}

model WorkflowSession {
  id                   String                @id @default(uuid()) @db.Uuid
  userId               String                @db.Uuid @map("user_id")
  workflowDefinitionId String?               @db.Uuid @map("workflow_definition_id")
  subjectType          WorkflowSubjectType?  @map("subject_type")
  subjectId            String?               @db.Uuid @map("subject_id")
  goal                 String?
  status               WorkflowSessionStatus @default(ACTIVE)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs WorkflowRun[]

  @@index([userId, createdAt])
  @@index([workflowDefinitionId])
  @@index([subjectType, subjectId])
  @@map("workflow_sessions")
}

model WorkflowRun {
  id           String             @id @default(uuid()) @db.Uuid
  sessionId    String             @db.Uuid @map("session_id")
  userId       String             @db.Uuid @map("user_id")
  status       WorkflowRunStatus  @default(PENDING)
  trigger      WorkflowRunTrigger @default(MANUAL)
  agentKind    String             @default("default") @map("agent_kind")
  model        String?
  summary      String?
  errorMessage String?            @map("error_message")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
  cancelledAt  DateTime?          @map("cancelled_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  session WorkflowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls RunToolCall[]
  artifactRefs RunArtifactRef[]

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@map("workflow_runs")
}

model RunToolCall {
  id           String            @id @default(uuid()) @db.Uuid
  runId        String            @db.Uuid @map("run_id")
  userId       String            @db.Uuid @map("user_id")
  toolName     String            @map("tool_name")
  status       RunToolCallStatus
  inputJson    Json              @map("input_json")
  outputJson   Json?             @map("output_json")
  errorCode    String?           @map("error_code")
  errorMessage String?           @map("error_message")
  errorJson    Json?             @map("error_json")
  startedAt    DateTime          @map("started_at")
  completedAt  DateTime          @map("completed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  run  WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([runId, createdAt])
  @@index([toolName, createdAt])
  @@map("run_tool_calls")
}

model RunArtifactRef {
  id           String             @id @default(uuid()) @db.Uuid
  runId        String             @db.Uuid @map("run_id")
  userId       String             @db.Uuid @map("user_id")
  artifactType RunArtifactRefType @map("artifact_type")
  artifactId   String             @db.Uuid @map("artifact_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  run  WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, artifactType, artifactId])
  @@index([userId, createdAt])
  @@index([runId, createdAt])
  @@index([artifactType, artifactId])
  @@map("run_artifact_refs")
}
